{
  "openapi": "3.0.1",
  "info": {
    "title": "GuestImporterApi",
    "version": "1.0"
  },
  "paths": {
    "/api/import/guests": {
      "post": {
        "tags": [
          "Import"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartImportRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StartImportRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StartImportRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/import/guests/{jobId}/progress": {
      "get": {
        "tags": [
          "Import"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/import/guests/{jobId}/cancel": {
      "post": {
        "tags": [
          "Import"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/import/guests/stop-all-background-jobs": {
      "post": {
        "tags": [
          "Import"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StartImportRequest": {
        "type": "object",
        "properties": {
          "csvFilePath": {
            "type": "string",
            "nullable": true
          },
          "batchSize": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}